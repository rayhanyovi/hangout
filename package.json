{
  "name": "hangout",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "db:migrate": "node scripts/run-db-migrations.mjs",
    "db:push": "npm run db:migrate",
