# Optional server runtime overrides for local development and deployment.
# Copy this file to `.env.local` only if you need to change the defaults.

# Durable room persistence for production and shared preview environments.
# When DATABASE_URL is set, Hangout uses PostgreSQL for rooms, members, votes, and cached venues.
# Run `npm run db:migrate` before first use so versioned SQL migrations are applied.
# `npm run db:schema:apply` remains available for applying the consolidated schema snapshot manually.
# DATABASE_URL=postgresql://hangout:secret@localhost:5432/hangout

# Required for the scheduled room cleanup cron route on Vercel.
# Use a random string with at least 16 characters.
# CRON_SECRET=replace-with-random-16-plus-char-secret

HANGOUT_ENABLE_STRUCTURED_LOGS=true
HANGOUT_VENUE_CACHE_TTL_SECONDS=120
HANGOUT_VENUE_STALE_TTL_SECONDS=360
HANGOUT_VENUE_RATE_LIMIT_WINDOW_SECONDS=30
HANGOUT_VENUE_RATE_LIMIT_MAX_REQUESTS=6

# Optional: override the fallback temporary room store location when DATABASE_URL is not set.
# Default: OS temp directory + /hangout
# HANGOUT_ROOM_STORE_DIR=C:\temp\hangout
