# Optional server runtime overrides for local development and deployment.
# Copy this file to `.env.local` only if you need to change the defaults.

HANGOUT_ENABLE_STRUCTURED_LOGS=true
HANGOUT_VENUE_CACHE_TTL_SECONDS=120
HANGOUT_VENUE_STALE_TTL_SECONDS=360
HANGOUT_VENUE_RATE_LIMIT_WINDOW_SECONDS=30
HANGOUT_VENUE_RATE_LIMIT_MAX_REQUESTS=6

# Optional: override the temporary room store location.
# Default: OS temp directory + /hangout
# HANGOUT_ROOM_STORE_DIR=C:\temp\hangout
